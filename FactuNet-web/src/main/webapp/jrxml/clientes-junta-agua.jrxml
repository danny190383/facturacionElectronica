	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="empresa" class="java.lang.Integer"/>
	<parameter name="grupo" class="java.lang.String"/>
	<parameter name="gruposBuscar" class="java.util.List"/>
	<queryString>
		<![CDATA[select 
persona.codigo,
persona.cedula,
persona.nombres,
persona.apellidos,
persona.direccion,
persona.email,
persona.telefono,
mantenimiento.nombre as grupo,
producto.codigo_barras,
producto.nombre as producto,
servicio_persona.estado
from servicio_persona inner join producto on 
producto.codigo = servicio_persona.servicio inner join persona on 
persona.codigo = servicio_persona.persona  inner join grupo_producto on
 grupo_producto.codigo = producto.grupo inner join mantenimiento on
 mantenimiento.codigo = grupo_producto.codigo
 where 
 (
CASE $P{grupo} 
    WHEN '1' then $X{IN, grupo_producto.codigo,gruposBuscar} 
    WHEN '2' then grupo_producto.codigo::text like '%%'
end
)
order by producto.codigo_barras]]>
	</queryString>
